// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: watch",
			"type": "shell",
			"command": "cmd",
			"args": ["/c", "npx tsc -watch -p ./"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "tsc: build",
			"type": "shell",
			"command": "cmd",
			"args": ["/c", "npx tsc -p ./"],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": "$tsc",
			"group": "build",
			"presentation": {
				"reveal": "silent"
			}
		}
	]
}
