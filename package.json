{
  "name": "dart-clean-architecture-hex",
  "displayName": "Flutter Clean Architecture (Melos Support)",
  "publisher": "FlutterCleanArchitecture",
  "description": "🏗️ Genera automáticamente Clean Architecture para Flutter/Dart. Soporte completo para Monorepos Melos. Ahorra tiempo con estructura organizada desde el día 1.",
  "author": {
    "name": "Chiuchiolo Sergio Edgardo"
  },
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.77.0"
  },
  "categories": [
    "Programming Languages",
    "Extension Packs",
    "Other"
  ],
  "icon": "images/logo-vs.png",
  "galleryBanner": {
    "color": "#C80000",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/chiuchiolo30/vscode-extension-arq-hex/issues",
    "email": "chiuchiolo30@gmail.com"
  },
  "homepage": "https://github.com/chiuchiolo30/vscode-extension-arq-hex/blob/master/README.md",
  "repository": {
      "type": "git",
      "url": "https://github.com/chiuchiolo30/vscode-extension-arq-hex"
  },
  "license": "MIT",
  "keywords": [
    "flutter",
    "dart",
    "clean architecture",
    "hexagonal architecture",
    "melos",
    "monorepo",
    "architecture",
    "code generator",
    "boilerplate",
    "scaffold",
    "domain driven design",
    "ddd",
    "use case",
    "repository pattern"
  ],
  "activationEvents": [
    "onLanguage:dart"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flutter-arq-hex.createFeature",
        "title": "Clean Architecture - Create feature without CRUD"
      },
      {
        "command": "flutter-arq-hex.createFeatureWithCrud",
        "title": "Clean Architecture - Create feature with CRUD"
      },
      {
        "command": "flutter-arq-hex.createUseCase",
        "title": "Clean Architecture - Create use case"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.77.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "eslint": "^8.36.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5",
    "@vscode/test-electron": "^2.3.0"
  }
}
